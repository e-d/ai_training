---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import LessonCard from '../../../components/LessonCard.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({
    params: { slug: course.data.slug },
    props: { course },
  }));
}

const { course } = Astro.props;
const allLessons = await getCollection('lessons');
const lessons = allLessons
  .filter((lesson) => lesson.data.course === course.data.slug)
  .sort((a, b) => a.data.order - b.data.order);
const allQuizzes = await getCollection('quizzes');
const courseQuiz = allQuizzes.find((q) => q.data.course === course.data.slug);
---

<BaseLayout title={course.data.title} description={course.data.description}>
  <div class="container course-overview">
    <Breadcrumbs items={[
      { label: 'Home', href: import.meta.env.BASE_URL },
      { label: course.data.title },
    ]} />

    <header class="course-overview__header">
      <h1 class="course-overview__title">{course.data.title}</h1>
      <p class="course-overview__description">{course.data.description}</p>
      <p class="course-overview__meta">{lessons.length} lessons</p>
    </header>

    <section class="course-overview__lessons">
      <h2 class="course-overview__section-title">Lessons</h2>
      <div class="course-overview__list">
        {lessons.map((lesson) => (
          <LessonCard
            title={lesson.data.title}
            description={lesson.data.description}
            order={lesson.data.order}
            slug={lesson.data.slug}
            courseSlug={course.data.slug}
          />
        ))}
      </div>
    </section>

    {courseQuiz && (
      <section class="course-overview__quiz">
        <h2 class="course-overview__section-title">Test Your Knowledge</h2>
        <a href={`${import.meta.env.BASE_URL}courses/${course.data.slug}/quiz/`} class="course-overview__quiz-card">
          <div class="course-overview__quiz-info">
            <h3 class="course-overview__quiz-title">{courseQuiz.data.title}</h3>
            <p class="course-overview__quiz-desc">{courseQuiz.data.description}</p>
            <span class="course-overview__quiz-meta">{courseQuiz.data.questions.length} questions</span>
          </div>
          <svg class="course-overview__quiz-arrow" width="24" height="24" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .course-overview {
    padding-bottom: var(--space-16);
  }

  .course-overview__header {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .course-overview__title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .course-overview__description {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
    max-width: 48rem;
    margin-bottom: var(--space-3);
  }

  .course-overview__meta {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    font-weight: 600;
  }

  .course-overview__section-title {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .course-overview__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .course-overview__quiz {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .course-overview__quiz-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    transition: background-color 0.15s ease, box-shadow 0.15s ease;
  }

  .course-overview__quiz-card:hover {
    background-color: var(--color-bg-alt);
    box-shadow: var(--shadow-sm);
    color: inherit;
  }

  .course-overview__quiz-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .course-overview__quiz-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-primary);
  }

  .course-overview__quiz-desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
  }

  .course-overview__quiz-meta {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .course-overview__quiz-arrow {
    color: var(--color-text-light);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .course-overview__quiz-card:hover .course-overview__quiz-arrow {
    transform: translateX(2px);
  }
</style>
