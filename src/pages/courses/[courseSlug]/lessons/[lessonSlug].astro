---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import LessonNav from '../../../../components/LessonNav.astro';

export async function getStaticPaths() {
  const allLessons = await getCollection('lessons');
  const allCourses = await getCollection('courses');
  const allQuizzes = await getCollection('quizzes');

  const paths = [];

  for (const lesson of allLessons) {
    const course = allCourses.find((c) => c.data.slug === lesson.data.course);
    if (!course) continue;

    const courseLessons = allLessons
      .filter((l) => l.data.course === lesson.data.course)
      .sort((a, b) => a.data.order - b.data.order);

    const lessonIndex = courseLessons.findIndex((l) => l.data.slug === lesson.data.slug);
    const prev = courseLessons[lessonIndex - 1];
    const next = courseLessons[lessonIndex + 1];

    let nextLesson = next
      ? { title: next.data.title, slug: next.data.slug, courseSlug: course.data.slug }
      : undefined;

    if (!next) {
      const courseQuiz = allQuizzes.find((q) => q.data.course === course.data.slug);
      if (courseQuiz) {
        nextLesson = {
          title: 'Course Quiz',
          slug: 'quiz',
          courseSlug: course.data.slug,
          href: `/courses/${course.data.slug}/quiz/`,
        };
      }
    }

    paths.push({
      params: {
        courseSlug: course.data.slug,
        lessonSlug: lesson.data.slug,
      },
      props: {
        lesson,
        course,
        prevLesson: prev ? { title: prev.data.title, slug: prev.data.slug, courseSlug: course.data.slug } : undefined,
        nextLesson,
      },
    });
  }

  return paths;
}

const { lesson, course, prevLesson, nextLesson } = Astro.props;
const { Content } = await render(lesson);
---

<BaseLayout title={lesson.data.title} description={lesson.data.description}>
  <div class="container lesson-page">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: course.data.title, href: `/courses/${course.data.slug}/` },
      { label: lesson.data.title },
    ]} />

    <article class="lesson-page__article">
      <header class="lesson-page__header">
        <span class="lesson-page__number">Lesson {lesson.data.order}</span>
        <h1 class="lesson-page__title">{lesson.data.title}</h1>
        <p class="lesson-page__description">{lesson.data.description}</p>
      </header>

      <div class="lesson-page__content prose">
        <Content />
      </div>

      <LessonNav prevLesson={prevLesson} nextLesson={nextLesson} />
    </article>
  </div>
</BaseLayout>

<style>
  .lesson-page {
    padding-bottom: var(--space-16);
  }

  .lesson-page__article {
    max-width: 48rem;
  }

  .lesson-page__header {
    padding: var(--space-6) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .lesson-page__number {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .lesson-page__title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .lesson-page__description {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
  }

  .lesson-page__content {
    padding: var(--space-8) 0;
  }

  /* Prose styles for rendered MDX content */
  .prose :global(h2) {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .prose :global(h3) {
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-4);
    line-height: var(--line-height-relaxed);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--line-height-relaxed);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  .prose :global(code) {
    background-color: var(--color-bg-alt);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.875em;
  }

  .prose :global(pre) {
    background-color: var(--color-primary);
    color: #e2e8f0;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: var(--text-sm);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }
</style>
