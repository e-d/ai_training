---
interface Props {
  title: string;
  description: string;
  order: number;
  slug: string;
  courseSlug: string;
}

const { title, description, order, slug, courseSlug } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}courses/${courseSlug}/lessons/${slug}/`} class="lesson-card">
  <span class="lesson-card__number">Lesson {order}</span>
  <div class="lesson-card__body">
    <h4 class="lesson-card__title">{title}</h4>
    <p class="lesson-card__desc">{description}</p>
  </div>
  <svg class="lesson-card__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
    <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</a>

<style>
  .lesson-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    transition: background-color 0.15s ease, box-shadow 0.15s ease;
  }

  .lesson-card:hover {
    background-color: var(--color-bg-alt);
    box-shadow: var(--shadow-sm);
    color: inherit;
  }

  .lesson-card__number {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    white-space: nowrap;
    min-width: 5rem;
  }

  .lesson-card__body {
    flex: 1;
    min-width: 0;
  }

  .lesson-card__title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .lesson-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--line-height-normal);
  }

  .lesson-card__arrow {
    color: var(--color-text-light);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .lesson-card:hover .lesson-card__arrow {
    transform: translateX(2px);
  }

  @media (max-width: 480px) {
    .lesson-card {
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .lesson-card__number {
      min-width: auto;
      width: 100%;
    }

    .lesson-card__arrow {
      display: none;
    }
  }
</style>
