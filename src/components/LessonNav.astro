---
interface LessonLink {
  title: string;
  slug: string;
  courseSlug: string;
}

interface Props {
  prevLesson?: LessonLink;
  nextLesson?: LessonLink;
}

const { prevLesson, nextLesson } = Astro.props;
---

<nav aria-label="Lesson navigation" class="lesson-nav">
  <div class="lesson-nav__inner">
    {prevLesson ? (
      <a href={`/courses/${prevLesson.courseSlug}/lessons/${prevLesson.slug}/`} class="lesson-nav__link lesson-nav__link--prev">
        <svg class="lesson-nav__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M13 16l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="lesson-nav__text">
          <span class="lesson-nav__label">Previous</span>
          <span class="lesson-nav__title">{prevLesson.title}</span>
        </span>
      </a>
    ) : (
      <span />
    )}
    {nextLesson ? (
      <a href={`/courses/${nextLesson.courseSlug}/lessons/${nextLesson.slug}/`} class="lesson-nav__link lesson-nav__link--next">
        <span class="lesson-nav__text">
          <span class="lesson-nav__label">Next</span>
          <span class="lesson-nav__title">{nextLesson.title}</span>
        </span>
        <svg class="lesson-nav__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    ) : (
      <span />
    )}
  </div>
</nav>

<style>
  .lesson-nav {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .lesson-nav__inner {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    gap: var(--space-4);
  }

  .lesson-nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    transition: background-color 0.15s ease, box-shadow 0.15s ease;
    max-width: 50%;
  }

  .lesson-nav__link:hover {
    background-color: var(--color-bg-alt);
    box-shadow: var(--shadow-sm);
    color: inherit;
  }

  .lesson-nav__link--next {
    margin-left: auto;
    text-align: right;
  }

  .lesson-nav__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .lesson-nav__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }

  .lesson-nav__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    line-height: var(--line-height-normal);
  }

  .lesson-nav__arrow {
    color: var(--color-text-light);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .lesson-nav__link--prev:hover .lesson-nav__arrow {
    transform: translateX(-2px);
  }

  .lesson-nav__link--next:hover .lesson-nav__arrow {
    transform: translateX(2px);
  }

  @media (max-width: 480px) {
    .lesson-nav__inner {
      flex-direction: column;
    }

    .lesson-nav__link {
      max-width: 100%;
    }

    .lesson-nav__link--next {
      margin-left: 0;
    }
  }
</style>
