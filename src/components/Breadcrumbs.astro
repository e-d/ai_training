---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="breadcrumbs">
  <ol class="breadcrumbs__list">
    {items.map((item, index) => (
      <li class="breadcrumbs__item">
        {index > 0 && <span class="breadcrumbs__sep" aria-hidden="true">/</span>}
        {item.href && index < items.length - 1 ? (
          <a href={item.href} class="breadcrumbs__link">{item.label}</a>
        ) : (
          <span class="breadcrumbs__current" aria-current={index === items.length - 1 ? "page" : undefined}>{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    padding: var(--space-4) 0;
  }

  .breadcrumbs__list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
    font-size: var(--text-sm);
  }

  .breadcrumbs__item {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .breadcrumbs__sep {
    color: var(--color-text-light);
  }

  .breadcrumbs__link {
    color: var(--color-text-light);
    transition: color 0.15s ease;
  }

  .breadcrumbs__link:hover {
    color: var(--color-accent);
  }

  .breadcrumbs__current {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
