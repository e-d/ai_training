{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "lessonCount": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "coming-soon"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "slug",
    "description",
    "order",
    "lessonCount",
    "status"
  ]
}