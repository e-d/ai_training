{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "course": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "scenario": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "choices": {
            "minItems": 4,
            "maxItems": 4,
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correctIndex": {
            "type": "number",
            "minimum": 0,
            "maximum": 3
          },
          "explanation": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "scenario",
          "question",
          "choices",
          "correctIndex",
          "explanation"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "slug",
    "course",
    "description",
    "questions"
  ]
}